DATABASE_URL=file:/home/z/my-project/db/custom.db

# Trial access passcode — shared with trial users via your website/email
TRIAL_PASSCODE=PANTRY&POT

# NextAuth secret — generate a new one for production with: openssl rand -base64 32
NEXTAUTH_SECRET=dev-secret-change-me-in-production-abc123
NEXTAUTH_URL=http://localhost:3000

# Payhip product URL for "Subscribe" button (set to your Payhip product link)
PAYHIP_URL=https://payhip.com
NEXT_PUBLIC_PAYHIP_URL=https://payhip.com

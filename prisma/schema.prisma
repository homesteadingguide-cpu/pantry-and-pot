// Prisma schema for Pantry and Pot

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  trialStartedAt DateTime @default(now())
  paidUntil      DateTime? // null = trial-only; future date = paid through then
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tasks         Task[]
  plantings     Planting[]
  batches       Batch[]
  pantryItems   PantryItem[]
  shoppingItems ShoppingItem[]
  settings      Setting[]
}

model Task {
  id          String   @id @default(cuid())
  title       String
  notes       String?
  category    String   @default("general")
  recurrence  String   @default("none")
  dueDate     DateTime?
  completed   Boolean  @default(false)
  completedAt DateTime?
  priority    String   @default("normal")
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Planting {
  id              String   @id @default(cuid())
  crop            String
  variety         String?
  spot            String?
  status          String   @default("planned")
  datePlanted     DateTime?
  expectedHarvest DateTime?
  actualHarvest   DateTime?
  quantity        Int      @default(1)
  notes           String?
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Batch {
  id          String   @id @default(cuid())
  type        String
  name        String
  status      String   @default("active")
  startDate   DateTime?
  expectedEnd DateTime?
  actualEnd   DateTime?
  lastFedAt   DateTime?
  notes       String?
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PantryItem {
  id         String   @id @default(cuid())
  name       String
  category   String   @default("dry")
  quantity   Float    @default(1)
  unit       String   @default("jar")
  lowStockAt Float?
  location   String?
  dateAdded  DateTime @default(now())
  notes      String?
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ShoppingItem {
  id           String   @id @default(cuid())
  name         String
  quantity     Float    @default(1)
  unit         String   @default("pack")
  notes        String?
  gotAt        DateTime?
  pantryItemId String?
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Setting {
  key       String   @id
  value     String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt DateTime @updatedAt
}

# Database URL — local SQLite for dev, hosted Postgres for production
DATABASE_URL=file:./db/custom.db

# Trial access passcode — share this with trial users via your website/email
TRIAL_PASSCODE=PANTRYPOT

# Paid passcode — give this to paying customers via Payhip
PAID_PASSCODE=PANTRYPAID

# NextAuth secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=dev-secret-change-me-in-production-abc123
NEXTAUTH_URL=http://localhost:3000

# Payhip product URL for "Subscribe" button
PAYHIP_URL=https://payhip.com
NEXT_PUBLIC_PAYHIP_URL=https://payhip.com
